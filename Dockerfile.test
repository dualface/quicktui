FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    curl ca-certificates python3 tmux locales \
    && locale-gen en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

COPY q.sh /workspace/q.sh
COPY tests /workspace/tests
RUN chmod +x /workspace/q.sh /workspace/tests/test_install.sh /workspace/tests/check_snapshots.sh

CMD ["sh", "/workspace/tests/test_install.sh"]
