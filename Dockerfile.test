FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    curl ca-certificates python3 tmux \
    && rm -rf /var/lib/apt/lists/*

COPY install.sh /workspace/install.sh
COPY tests/test_install.sh /workspace/tests/test_install.sh
RUN chmod +x /workspace/install.sh /workspace/tests/test_install.sh

CMD ["sh", "/workspace/tests/test_install.sh"]
